# Auth0 Configuration for Borrower Portal
# Required for @auth0/nextjs-auth0 SDK (Server-side only - no NEXT_PUBLIC_ prefix)
# See AUTH0_SETUP.md for detailed setup instructions
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_BASE_URL=http://localhost:3000
AUTH0_SECRET=generate_a_long_random_string_at_least_32_characters

# OpenAI Configuration (Server-side only)
OPENAI_API_KEY=your_openai_api_key_here

# SharePoint Configuration (Server-side only)
# Format: https://[hostname].sharepoint.com/sites/[sitename]
# Example: https://contoso.sharepoint.com/sites/mysite
SHAREPOINT_SITE_URL=https://your_tenant.sharepoint.com/sites/your_site
SHAREPOINT_CLIENT_ID=your_app_client_id
SHAREPOINT_CLIENT_SECRET=your_app_client_secret
SHAREPOINT_TENANT_ID=your_azure_tenant_id
# Optional: Parent folder path for project folders (leave empty to use root)
# Path is relative to the document library root (don't include "Documents" or "Shared Documents")
# Example: Dev-Working/SBA Loans or My Folder/Projects
# SHAREPOINT_PARENT_FOLDER_PATH=

# TODO: Add Azure / Microsoft Entra ID configuration here
COSMOS_CONNECTION_STRING=mongodb://your-account:your-key@your-account.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&maxIdleTimeMS=120000&appName=@your-account@
COSMOS_DATABASE=your_database_name